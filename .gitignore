# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# misc / temp files
deployment-*.txt
deployerroroncoolify.md
*.csv

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# keep example files so forkers have a template to copy
!.env.local.example
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# capacitor — native build artifacts
# The android/ and ios/ directories are committed so GitHub Actions
# can build the APK/IPA. Only ignore generated build outputs.
android/app/build/
android/.gradle/
android/build/
android/capacitor-cordova-android-plugins/build/
ios/App/build/
ios/App/Pods/
